{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "external_extraction_v1",
  "description": "projMap extraction result format — aligned with schemas.py ExtractedNode/ExtractedEdge",
  "type": "object",
  "required": ["nodes", "edges"],
  "properties": {
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "content", "evidence_quote", "confidence"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["decision", "constraint", "assumption", "risk", "version", "config", "implementation_fact", "evaluation_result", "process_rule", "open_question", "raw_extraction_fragment"]
          },
          "title": { "type": "string", "maxLength": 300, "description": "Short decision name or label." },
          "content": { "type": "string", "minLength": 20, "maxLength": 500, "description": "Complete self-contained sentence with subject." },
          "summary": { "type": "string", "maxLength": 500 },
          "context": { "type": "string", "maxLength": 1000, "description": "What system/module and why it matters." },
          "rationale": { "type": "string", "maxLength": 1000, "description": "Why this choice was made." },
          "scope": { "type": "string", "maxLength": 500 },
          "non_goals": { "type": "array", "items": { "type": "string" } },
          "status_hint": { "type": ["string", "null"] },
          "project_hint": { "type": ["string", "null"] },
          "version_hint": { "type": ["string", "null"] },
          "module_hint": { "type": ["string", "null"] },
          "submodule_hint": { "type": ["string", "null"] },
          "topic_hint": { "type": ["string", "null"] },
          "entities": { "type": "array", "items": { "type": "string" } },
          "detail": { "type": "string", "maxLength": 500 },
          "source_line": { "type": ["string", "integer", "null"] },
          "source_heading": { "type": ["string", "null"] },
          "line_start": { "type": ["integer", "null"] },
          "line_end": { "type": ["integer", "null"] },
          "explicit_date_hint": { "type": ["string", "null"], "description": "YYYY-MM-DD if a specific date is mentioned." },
          "classification_confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
          "evidence_quote": { "type": "string", "minLength": 5, "maxLength": 1000, "description": "Verbatim quote from source chunk." },
          "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["relationship", "evidence_quote", "confidence"],
        "properties": {
          "from_title": { "type": "string", "maxLength": 300 },
          "from_content": { "type": "string", "maxLength": 500, "description": "Must match or closely match a node content." },
          "to_title": { "type": "string", "maxLength": 300 },
          "to_content": { "type": "string", "maxLength": 500, "description": "Must match or closely match a node content." },
          "relationship": {
            "type": "string",
            "enum": ["depends-on", "conflicts-with", "supersedes", "traces-back-to", "mitigates", "implements", "affects", "supports", "limits"]
          },
          "evidence_quote": { "type": "string", "minLength": 5, "maxLength": 1000, "description": "Verbatim quote showing this relationship." },
          "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
        }
      }
    }
  }
}
